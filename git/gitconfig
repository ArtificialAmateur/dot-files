[user]
	name = Frank Tursi
	useConfigOnly = true
[includeIf "gitdir:~/Work/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/Projects/"]
	path = ~/.gitconfig-personal
[protocol "gcrypt"]
	allow = always
[color]
	ui = auto
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
[gcrypt]
	teamkeys = /home/user/Work/teamkeys
[push]
	autoSetupRemote = true
[alias]
    sr = submodule foreach --recursive --quiet 'cd $toplevel && git submodule update $sm_path'
	gpush = !git fetch && git push

[pull]
	rebase = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultbranch = main
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
