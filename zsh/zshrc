# Sets completions format:
zstyle ':completion:*:descriptions' format '%U%B%d%b%u'

# Gives error if no matches appear:
zstyle ':completion:*:warnings' format '%BSorry, no matches for: %d%b'

## Functions

# Update OS
function update-all () {
	if [[ "$OSTYPE" == "linux-gnu"* ]]
	then
		OS=$(awk -F= '$1=="ID" { print $2 ;}' /etc/os-release) 
		if [[ $OS == 'debian' ]]
		then
			update-apt
		elif [[ $OS == 'arch' ]]
		then
			paru
		fi
		if cmd_loc="$(type -p "flatpak")"  && [[ ! -z $cmd_loc ]]
		then
			update-flatpak
		fi
		if cmd_loc="$(type -p "fwupdmgr")"  && [[ ! -z $cmd_loc ]]
		then
			update-fw
		fi
	elif [[ "$OSTYPE" == "darwin"* ]]
	then
		brew update
		brew upgrade
		brew autoremove
		brew cleanup
	fi
	update-plugins
	if cmd_loc="$(type -p "tmux")"  && [[ ! -z $cmd_loc ]]
	then
		"$HOME/.tmux/plugins/tpm/bin/update_plugins" all
	fi
}

function update-apt () {
	sudo apt update
	sudo apt full-upgrade
	sudo apt autopurge
	sudo apt autoclean
}

function update-flatpak () {
	flatpak update
}

function update-fw () {
	sudo fwupdmgr refresh
	sudo fwupdmgr update
}

function update-git () {
	find "$HOME" -maxdepth 8 -name ".git" -prune -type d -printf "%h\n" | parallel --eta "echo {} && git -C {} stash && git -C {} pull --all"
}

function no-proxy () {
	env -u HTTP_PROXY -u http_proxy -u HTTPS_PROXY -u https_proxy -u NO_PROXY -u no_proxy -u CURL_CA_BUNDLE -- "$@"
}

build-push () {
	local build_path=$1 
	local binary=${build_path:t} 
	echo "make configure"
	make configure
	echo "make"
	make
	echo "adb push $build_path /data/local/tmp/$binary"
	adb push "$build_path" "/data/local/tmp/$binary"
}

build-push-run () {
	local build_path=$1 
	local binary=${build_path:t} 
	build-push "$build_path"
	shift
	echo "adb shell /data/local/tmp/$binary $@"
	adb shell "/data/local/tmp/$binary" "$@"
}

build_applogic_target () {
	export PATH="$PATH:$PWD"
	BUILD_TARGET=shell make $1
}

function update-plugins () {
	for d in "$HOME"/.zsh/plugins/*(/)
		git -C "$d" pull --ff-only
}

function mkcd () {
	mkdir -p "$1" && cd "$1"
}

function extract () {
	if [[ ! -f $1 ]]; then
		echo "extract: '$1' is not a file" >&2
		return 1
	fi
	case $1 in
		*.tar.bz2) tar xjf "$1" ;;
		*.tar.gz)  tar xzf "$1" ;;
		*.tar.xz)  tar xJf "$1" ;;
		*.tar.zst) tar --zstd -xf "$1" ;;
		*.tar)     tar xf "$1" ;;
		*.bz2)     bunzip2 "$1" ;;
		*.gz)      gunzip "$1" ;;
		*.xz)      unxz "$1" ;;
		*.zst)     unzstd "$1" ;;
		*.zip)     unzip "$1" ;;
		*.7z)      7z x "$1" ;;
		*.rar)     unrar x "$1" ;;
		*) echo "extract: unsupported format '$1'" >&2; return 1 ;;
	esac
}

# Displays a list of supported colors:
function lscolors {
	((cols = $COLUMNS - 4))
	s=$(printf %${cols}s)
	for i in {000..$(tput colors)}; do
		echo -e $i $(tput setaf $i; tput setab $i)${s// /=}$(tput op);
	done
}

# Launches a program:
function launch {
	type $1 >/dev/null || { print "$1 not found" && return 1 }
	$@ &>/dev/null &|
}

# Gets public ip address:
function myip {
	local api
	case "$1" in
		"-4")
			api="http://v4.ipv6-test.com/api/myip.php"
			;;
		"-6")
			api="http://v6.ipv6-test.com/api/myip.php"
			;;
		*)
			api="http://ipv6-test.com/api/myip.php"
			;;
	esac
	curl -s "$api"
	echo # Newline.
}

# Backup to remote restic
function remote {
    restic -r s3:https://s3.us-west-004.backblazeb2.com/photomahoganyresetjailer "$@"
}

function backup {
    REMOTE_REPO="s3:https://s3.us-west-004.backblazeb2.com/photomahoganyresetjailer"
    LOCAL_REPO="/Volumes/LaCie/restic"

    brew list --cask >> "$HOME/.brewlist"
    brew leaves --installed-on-request > "$HOME/.brewlist"
    while IFS='' read -r LINE || [ -n "${LINE}" ]; do
        dedup "${LINE}"
    done < "$HOME/.osx-restic"

    remote -v -r "$REMOTE_REPO" backup --files-from "$HOME/.osx-restic"

    if [ -d "$LOCAL_REPO" ]; then
      restic -v -r "$LOCAL_REPO" copy --from-repo "$REMOTE_REPO"
    fi
}

