## Plugins

ZPLUGINDIR="$HOME/.zsh/plugins"

plugins=(
	zsh-users/zsh-completions
	zsh-users/zsh-autosuggestions
	zsh-users/zsh-history-substring-search
	zdharma-continuum/fast-syntax-highlighting
	MichaelAquilina/zsh-you-should-use
)

for plugin in $plugins; do
	[[ -d "$ZPLUGINDIR/${plugin:t}" ]] || \
		git clone --depth 1 "https://github.com/$plugin" "$ZPLUGINDIR/${plugin:t}"
done

fpath+="$ZPLUGINDIR/zsh-completions/src"

# NOTE: fast-syntax-highlighting must be sourced last
source "$ZPLUGINDIR/zsh-you-should-use/you-should-use.plugin.zsh"
source "$ZPLUGINDIR/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$ZPLUGINDIR/zsh-history-substring-search/zsh-history-substring-search.zsh"
# NOTE: fast-syntax-highlighting can't be re-sourced (recursive widget wrapping)
[[ -z $_FSH_LOADED ]] && source "$ZPLUGINDIR/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" && _FSH_LOADED=1

# Bind up/down arrows to history substring search
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

eval "$(zoxide init zsh)"

